EMAIL_TELEGRAM_BOT_TOKEN=
EMAIL_TELEGRAM_CHAT_ID=
EMAIL_TELEGRAM_ALLOWED_CHAT_IDS=

FINANCE_TELEGRAM_BOT_TOKEN=
FINANCE_ADMIN_CHAT_IDS=
SAVING_GOAL_FEATURE_ENABLED=false

SCAN_LIMIT=20
FORWARD_THRESHOLD=70
POLL_INTERVAL_SECONDS=300

USE_OPENAI=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
FINANCE_OPENAI_MODEL=gpt-4.1-nano
RECEIPT_OCR_MODEL=gpt-4.1-mini

GOOGLE_SHEETS_ENABLED=false
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=
# Master template yang akan dicopy otomatis saat user pertama kali generate laporan.
GOOGLE_SHEETS_TEMPLATE_ID=
# Fallback lama. Jika template kosong, semua export memakai spreadsheet ini.
GOOGLE_SHEET_ID=
GOOGLE_SHEET_NAME=Laporan Keuangan
GOOGLE_SHEETS_SHARE_WITH_USER=true
GOOGLE_SHEETS_SHARE_ROLE=writer

# BACKEND_API_URL harus menunjuk ke KasGue Finance API (NestJS), mis. http://127.0.0.1:3000.
# Dipakai untuk laporan Google Sheets dan pengecekan langganan (paywall) sebelum mencatat transaksi.
# INTERNAL_API_KEY wajib sama dengan INTERNAL_API_KEY pada backend.
BACKEND_API_URL=http://127.0.0.1:3000
WEB_BASE_URL=http://localhost:3001
# Opsional untuk Telegram inline button saat WEB_BASE_URL masih localhost.
# Isi domain public, misalnya https://kasgue.com atau URL tunnel dev.
SUBSCRIPTION_PUBLIC_WEB_BASE_URL=
INTERNAL_API_KEY=

IMPORTANT_KEYWORDS=urgent,penting,invoice,payment,pembayaran,deadline,approval,kontrak,meeting,proposal
IMPORTANT_SENDERS=
